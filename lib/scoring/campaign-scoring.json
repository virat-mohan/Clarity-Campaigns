        "traffic": { "seo_aeo": 10, "social_organic": 6, "performance_marketing": 0, "outbound_sales": 0, "customer_retention": 0 },
        "followers": { "social_organic": 10, "performance_marketing": 0, "outbound_sales": 0, "seo_aeo": 0, "customer_retention": 0 },
