    "current_channels": {
      "label": "Current Acquisition Channels",
      "type": "multi",
      "_description": "Spec only gave 4 worked examples and no consistent formula could be reverse-engineered from them (checked algebraically — the three single-channel examples are mutually inconsistent, no clean per-channel weight table reproduces all three exactly). Implemented as an explicit lookup for exactly the documented combinations. Any other combination gets a neutral (all-zero) result until the product owner supplies more worked examples — see engine code comments.",
      "channelOptions": ["paid_ads", "organic", "referrals"],
      "explicitCombinations": {
        "none": { "performance_marketing": 6, "social_organic": 6, "seo_aeo": 6, "outbound_sales": 6, "customer_retention": 0 },
        "paid_ads": { "seo_aeo": 5, "social_organic": 4, "customer_retention": 4 },
        "organic": { "performance_marketing": 7, "outbound_sales": 4, "customer_retention": 3 },
        "referrals": { "outbound_sales": 6, "performance_marketing": 5, "seo_aeo": 4 }
      }
    },

    "assets_available": {
      "label": "Assets Available",
      "type": "multi",
      "_description": "Multi-select of assets the business is MISSING. missing_brand_guidelines deliberately does NOT reduce campaign scores per the spec (\"Instead of reducing recommendation confidence, reduce the Readiness Score\") — it is excluded from calculateScores() and only feeds calculateReadiness().",
      "scorePenalties": {
        "missing_website": { "performance_marketing": -8, "seo_aeo": -10 },
        "missing_crm": { "customer_retention": -6, "outbound_sales": -4 },
        "missing_analytics": { "performance_marketing": -5, "seo_aeo": -5, "customer_retention": -5 }
      },
      "readinessOnlyPenalties": {
        "missing_brand_guidelines": { "all": -2 }
      }
    }
  },

  "readiness": {
    "maxScore": 100,
    "components": {
      "website": 20,
      "brand_guidelines": 15,
      "crm": 15,
      "analytics": 15,
      "tracking_pixel": 10,
      "creative_assets": 10,
      "product_catalogue": 10,
      "marketing_automation": 5
    }
  },

  "roadmap": {
    "_description": "Spec states the roadmap should follow Acquisition -> Conversion -> Retention rather than pure score order. The worked example in the spec (Performance -> Retention -> SEO -> Social) actually contradicts this stated rule (Performance is a Conversion-stage campaign, not Acquisition). Implemented per the STATED rule (flywheelStage order), not the inconsistent example — flag this to the spec author.",
    "stageOrder": ["acquisition", "conversion", "retention"]
  }
}
